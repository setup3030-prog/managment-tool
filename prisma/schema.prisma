generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  industry      String
  country       String
  flag          String   @default("")
  annualVolume  Float?   @map("annual_volume")
  paymentTerms  String?  @map("payment_terms")
  creditRating  String?  @map("credit_rating")
  contacts      Json     @default("[]")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  claims        Claim[]
  pipelineDeals PipelineDeal[]

  @@map("customers")
}

model Claim {
  id          String      @id @default(cuid())
  customerId  String      @map("customer_id")
  title       String
  description String?
  status      ClaimStatus @default(OPEN)
  value       Float?
  priority    Priority    @default(MEDIUM)
  assignedTo  String?     @map("assigned_to")
  createdAt   DateTime    @default(now()) @map("created_at")
  resolvedAt  DateTime?   @map("resolved_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  customer    Customer    @relation(fields: [customerId], references: [id])

  @@map("claims")
}

enum ClaimStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model PipelineDeal {
  id              String    @id @default(cuid())
  customerId      String    @map("customer_id")
  title           String
  stage           DealStage @default(LEAD)
  value           Float?
  probability     Float?
  assignedTo      String?   @map("assigned_to")
  expectedClose   DateTime? @map("expected_close")
  notes           String?
  position        Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  customer        Customer  @relation(fields: [customerId], references: [id])

  @@map("pipeline_deals")
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model KpiSnapshot {
  id              String   @id @default(cuid())
  month           DateTime
  revenue         Float
  grossMarginPct  Float    @map("gross_margin_pct")
  onTimeDelivery  Float?   @map("on_time_delivery")
  cashBalance     Float    @map("cash_balance")
  quotesWon       Int?     @map("quotes_won")
  quotesLost      Int?     @map("quotes_lost")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([month])
  @@map("kpi_snapshots")
}

model UserProfile {
  id          String   @id
  email       String   @unique
  fullName    String?  @map("full_name")
  role        UserRole @default(ENGINEER)
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

enum UserRole {
  ADMIN
  SALES
  ENGINEER
  FINANCE
  VIEWER
}

model AppSettings {
  id                String   @id @default("singleton")
  defaultCurrency   String   @default("EUR") @map("default_currency")
  targetMarginPct   Float    @default(17) @map("target_margin_pct")
  warningMarginPct  Float    @default(12) @map("warning_margin_pct")
  targetOtdPct      Float    @default(95) @map("target_otd_pct")
  quoteExpiryDays   Int      @default(30) @map("quote_expiry_days")
  companyName       String   @default("Rocco Tools") @map("company_name")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
