# ─── Demo Mode ───────────────────────────────────────────────────────────────
# Set to "true" to run the app with hardcoded seed data (no database needed)
NEXT_PUBLIC_DEMO_MODE=true

# ─── Supabase (required when DEMO_MODE=false) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ─── Prisma / Database (required when DEMO_MODE=false) ───────────────────────
# Pooled connection (use for runtime queries, pgbouncer=true)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (use for prisma migrate / db push)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
